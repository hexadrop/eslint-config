{
	"name": "@hexadrop/eslint-config",
	"version": "1.0.6",
	"description": "Opinionated ESLint ruleset designed for large teams and projects",
	"keywords": [
		"lint",
		"eslint",
		"eslint-config",
		"monorepo",
		"scalable",
		"scale",
		"typescript",
		"prettier"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/hexadrop/eslint-config.git"
	},
	"homepage": "https://github.com/hexadrop/eslint-config",
	"bugs": {
		"url": "https://github.com/hexadrop/eslint-config/issues"
	},
	"license": "MIT",
	"type": "module",
	"files": [
		"dist"
	],
	"main": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"import": "./dist/index.mjs"
		}
	},
	"scripts": {
		"build": "bun run scripts/typegen.ts && tsdown",
		"build:types": "bun run scripts/typegen.ts",
		"lint": "eslint .",
		"lint:fix": "eslint --fix .",
		"prepublish": "bun run scripts/typegen.ts && tsdown",
		"typecheck": "tsc --noEmit"
	},
	"peerDependencies": {
		"eslint": "^9.17.0 || ^10.0.0"
	},
	"dependencies": {
		"@eslint/markdown": "8.0.3",
		"@stylistic/eslint-plugin": "5.10.0",
		"@typescript-eslint/eslint-plugin": "8.64.0",
		"@typescript-eslint/parser": "8.64.0",
		"astro-eslint-parser": "3.0.0",
		"eslint-config-flat-gitignore": "2.3.0",
		"eslint-flat-config-utils": "3.2.0",
		"eslint-import-resolver-typescript": "4.4.5",
		"eslint-merge-processors": "2.0.0",
		"eslint-parser-plain": "0.1.1",
		"eslint-plugin-astro": "3.0.0",
		"eslint-plugin-format": "2.0.1",
		"eslint-plugin-import-x": "4.17.1",
		"eslint-plugin-jsonc": "3.3.0",
		"eslint-plugin-n": "18.2.2",
		"eslint-plugin-perfectionist": "5.10.0",
		"eslint-plugin-react": "7.37.5",
		"eslint-plugin-react-hooks": "7.1.1",
		"eslint-plugin-react-refresh": "0.5.3",
		"eslint-plugin-simple-import-sort": "13.0.0",
		"eslint-plugin-unicorn": "71.1.0",
		"eslint-plugin-unused-imports": "4.4.1",
		"globals": "17.7.0",
		"jsonc-eslint-parser": "3.1.0",
		"local-pkg": "1.2.1",
		"prettier": "3.9.5",
		"prettier-plugin-astro": "0.14.1",
		"tslib": "2.8.1"
	},
	"devDependencies": {
		"@changesets/cli": "2.31.1",
		"@eslint/config-inspector": "3.1.0",
		"@hexadrop/tsconfig": "0.0.5",
		"@types/bun": "1.3.14",
		"astro": "7.1.3",
		"eslint": "10.7.0",
		"eslint-typegen": "2.3.1",
		"jiti": "2.7.0",
		"react": "19.2.8",
		"tsdown": "0.22.12",
		"typescript": "6.0.3"
	}
}
